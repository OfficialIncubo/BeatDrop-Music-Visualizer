# Generated with Gemini Pro 3.1

name: CMake Build

on:
  push:
    branches: ["**"]
  pull_request:
    branches: ["**"]
  workflow_dispatch: # Allows you to run this workflow manually

jobs:
  build:
    name: ${{ matrix.build_name }} (${{ matrix.os }})
    strategy:
      matrix:
        os: [windows-2022, windows-2025]
        config: [release, release-oldos, full-package]
        include:
          - config: release
            build_name: "Build Release Only"
            artifact_name: "BeatDrop-Release"
          - config: release-oldos
            build_name: "Build Release_OldOS Only"
            artifact_name: "BeatDrop-Release-OldOS"
          - config: full-package
            build_name: "Build Full Package"
            artifact_name: "BeatDrop-Full-Package"
    runs-on: ${{ matrix.os }}

    steps:
    - name: Checkout Repository
      uses: actions/checkout@v6

    - name: Add MSBuild to PATH
      uses: microsoft/setup-msbuild@v3

    - name: Clone and Build projectM-eval
      shell: bash
      run: |
        # Clone projectM-eval
        git clone https://github.com/projectM-visualizer/projectm-eval.git
        cd projectm-eval
        git fetch --all
        
        # Setup build directories
        mkdir projectm-eval-build
        cd projectm-eval-build
        
        # Generate project files and force BUILD_NS_EEL_SHIM to ON
        cmake -A Win32 -DBUILD_NS_EEL_SHIM=ON ..
        
        # Build and install
        cmake --build . --config "Release" --parallel
        cmake --install . --prefix projectm-eval-install

    - name: Copy projectM-eval libraries
      shell: bash
      run: |
        mkdir -p lib
        mkdir -p ns-eel2-shim
        cp projectm-eval/projectm-eval-build/projectm-eval-install/lib/projectM_eval.lib lib/
        cp projectm-eval/projectm-eval-build/projectm-eval-install/lib/projectM_ns-eel2.lib lib/
        cp projectm-eval/projectm-eval-build/projectm-eval-install/include/projectm-eval/ns-eel2/ns-eel.h ns-eel2-shim/

    - name: Install Legacy DirectX SDK
      shell: powershell
      run: |
        choco install directx-sdk -y
        # Setting environment variables for the current session
        echo "DXSDK_DIR=C:\Program Files (x86)\Microsoft DirectX SDK (June 2010)" >> $env:GITHUB_ENV

    - name: Build BeatDrop (Release)
      if: matrix.config == 'release' || matrix.config == 'full-package'
      shell: cmd
      env:
        INCLUDE: 'C:\Program Files (x86)\Microsoft DirectX SDK (June 2010)\Include;%INCLUDE%'
        LIB: 'C:\Program Files (x86)\Microsoft DirectX SDK (June 2010)\Lib\x86;%LIB%'
      run: |
        :: Build the main project solution using the Release configuration
        msbuild BeatDrop.sln /p:Configuration="Release" /p:Platform="Win32" /m

    - name: Copy BeatDrop executable to package
      if: matrix.config == 'release' || matrix.config == 'full-package'
      shell: bash
      run: |
        mkdir -p BeatDrop
        cp vis_milk2/Release/BeatDrop.exe BeatDrop/

    - name: Build BeatDrop (Release_OldOS)
      if: matrix.config == 'release-oldos' || matrix.config == 'full-package'
      shell: cmd
      env:
        INCLUDE: 'C:\Program Files (x86)\Microsoft DirectX SDK (June 2010)\Include;%INCLUDE%'
        LIB: 'C:\Program Files (x86)\Microsoft DirectX SDK (June 2010)\Lib\x86;%LIB%'
      run: |
        :: Build the main project solution using the Release_OldOS configuration
        msbuild BeatDrop.sln /p:Configuration="Release_OldOS" /p:Platform="Win32" /m

    - name: Copy BeatDrop_OldOS executable to package
      if: matrix.config == 'release-oldos' || matrix.config == 'full-package'
      shell: bash
      run: |
        mkdir -p BeatDrop
        cp vis_milk2/Release/BeatDrop_OldOS.exe BeatDrop/

    - name: Post-Build Packaging
      shell: bash
      run: |
        # Create destination directories
        mkdir -p "BeatDrop/BeatDrop Resources"
        
        # Copy resources
        cp -R resources/Milkdrop2/* "BeatDrop/BeatDrop Resources/"
        cp resources/precache.txt BeatDrop/

    - name: Upload Build Artifact
      uses: actions/upload-artifact@v7
      with:
        name: ${{ matrix.artifact_name }}-${{ matrix.os }}
        path: BeatDrop/