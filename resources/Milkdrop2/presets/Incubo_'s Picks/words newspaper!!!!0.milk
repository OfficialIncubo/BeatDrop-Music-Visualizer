shapecode_2_border_a=0.100
shape_2_init1=a=1; x=x-0.2*instance; y=y-0.02*instance+1; rad=0.99;
shape_2_per_frame1=t10=q10*0.4; t11=instance*0.3; t12=(1-t10)-t11;
shape_2_per_frame2=x = sin(time)*t12 * .4 + (.5+t10*sin(time));
shape_2_per_frame3=rad=sin(time*0.5) *0.4 +0.5*(treb_att*0.02);
shape_2_per_frame4=rad=rad*1+t10;
shape_2_per_frame5=y= cos(time*0.6)*t11 *.4 + .5+(0.001*(bass*t10));
shape_2_per_frame6=a=1-t11;
shape_2_per_frame7=
shape_2_per_frame8=r=(r*rtreb)*a;
shape_2_per_frame9=g=(g*mid)*a;
shape_2_per_frame10=b=(b*bass)*a;
shape_2_per_frame11=r2=1-g;
shape_2_per_frame12=g2=1-b;
shape_2_per_frame13=b2=1-r;
shape_2_per_frame14=pow( (bass*.15),2);
shapecode_3_enabled=0
shapecode_3_sides=7
shapecode_3_additive=1
