shape_3_init1=ang=1-ang;
shape_3_per_frame1=ang =((mid_att + treb -bass_att) + (treb_att + mid -bass*instance))*sin(time*0.3)*0.03;
shape_3_per_frame2=//tex_ang=1- (ang*0.1);
shape_3_per_frame3=//tex_zoom=0.02 +ang*instance;
per_frame_1=wzoom = 0.18*sin(time);
per_frame_2=q3=wzoom;
per_frame_3=q1 = 0.8 - 0.3*sin(-time*1.3);
per_frame_4=q2 = 0.8 - 0.3*cos(-time);
per_frame_5=monitor=fps;
per_frame_6=vol = 0.1*(vol*9 + (bass_att+mid_att+treb_att)*0.333333);
per_frame_7=q20 = vol;
per_frame_8=
per_frame_9=mtime = mtime+vol*0.05;
per_frame_10=rx = 0.3+0.05*sin(mtime*0.3);
per_frame_11=ry = 0.5+0.05*sin(mtime*0.4);
per_frame_12=q4=rx;
per_frame_13=q5=ry;
per_frame_14=tx = 0.5+0.4*sin(mtime*0.18);
per_frame_15=ty = 0.5+1.3*sin(mtime*0.14);
per_frame_16=q6=tx;
per_frame_17=q7=ty;
per_frame_18=
per_frame_19=tr = 0.5 + 0.4*(0.6*sin(mtime*0.64) + 0.4*sin(mtime*0.32));
per_frame_20=tb = 0.5 + 0.4*(0.6*sin(-mtime*0.24) + 0.4*sin(mtime*0.72));
per_frame_21=tg = 0.5 + 0.4*(0.6*sin(mtime*0.42) + 0.4*cos(mtime*0.50));
per_frame_22=q11=tr;
per_frame_23=q12=tg;
per_frame_24=q13=rb;
per_frame_25=
per_frame_26=
per_frame_27=
per_frame_28=bass_thresh = above(bass_att,bass_thresh)*2 + 
per_frame_29=    (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);
per_frame_30=count = equal(bass_thresh, 2)*1 + (1-equal(bass_thresh, 2))*count;
per_frame_31=count = count - above(count, 0.02)*0.02;
per_frame_32=q10=count;
per_frame_33=
per_frame_34=// raytraced sphere code
per_frame_35=
per_frame_36=d =min(15-(1/fps)*2, 20+(4*(1/fps))*cos(time/5)); // distance of the sphere, the farther you're away the more you'll see on the horizon
per_frame_37=z = 0.4; // distance of the pane where the scene is projected on, wider distance = smaller apex angle of the camera, very small distances = fish eyes view
per_frame_38=
per_frame_39=zz = 10 + bass_att*2; // linear zoom
per_frame_40=
per_frame_41=pi = asin(1)*2;
per_frame_42=pi2inv = 0.5/pi;
per_frame_43=maskangle = asin( 1/d);
per_frame_44=q32 = maskangle; // hit = (cameras angle < mask_angle)
per_frame_45=q31 = d;
per_frame_46=q30 = z;
per_frame_47=q29 = pi2inv;
per_frame_48=q28 = pi;
per_frame_49=q27 = 1/zz;
per_frame_50=q26 = time;
per_frame_51=v = 0.4;
per_frame_52=j1 = j1*0.95 + sqr(bass*4)*v;
per_frame_53=j2 = j2*0.95 + sqr(mid*4)*v;
per_frame_54=j3 = j3*0.95 + sqr(treb*4)*v;
per_frame_55=
per_frame_56=n = n + j1*0.0052;
per_frame_57=n1 = n1 + j2*0.0052;
per_frame_58=n2 = n2 + j3*0.0052;
per_frame_59=
per_frame_60=
per_frame_61=w1 = n*0.01;    // solid angles to rotate the sphere in its origin
per_frame_62=w2 = n1*0.01;
per_frame_63=w3 = n2*0.01;
per_frame_64=
per_frame_65=q20 = cos(w1);
per_frame_66=q21 = sin(w1);
per_frame_67=q22 = cos(w2);
per_frame_68=q23 = sin(w2);
per_frame_69=q24 = cos(w3);
per_frame_70=q25 = sin(w3);
warp_1=`sampler sampler_fw_rand07;
warp_2=`shader_body
warp_3=`{
warp_4=`    // sample previous frame
warp_5=`    ret = tex2D( sampler_main, uv ).z;
warp_6=`    
warp_7=`    // darken (decay) over time
warp_8=`    ret *= 0.999; //or try: ret -= 0.004;
warp_9=`ret = tex2d(sampler_fw_rand07, uv);
warp_10=`}
comp_1=`shader_body
comp_2=`{
comp_3=`
comp_4=`
comp_5=`
comp_6=`
comp_7=`// ***** Martin's ripples on water surface code, parameterized by Flexi *****
comp_8=`
comp_9=`float h = q9;                      // height of the horizon
comp_10=`float cut_off = 0.0;              // cut off lower border
comp_11=`float2 t = float2(0.1,-0.05)*time;  // velocity
comp_12=`float strength = 0.025;
comp_13=`
comp_14=`
comp_15=`float2 c = uv_orig-float2(0.5,1-h);
comp_16=`float z = 3/c.y;
comp_17=`float2 uv_water = float2(c.x*z*h,z*h)*0.05+t;
comp_18=`int mask = (c.y>0);
comp_19=`uv_water = (tex2D(sampler_noise_hq,uv_water)-0.5)*mask;
comp_20=`float2 uv_mirror = 1.0-abs(frac((c+float2(0.5,1))*0.5)*2-1)+float2(0,-cut_off);
comp_21=`uv_mirror =frac(uv_mirror-uv_water.xy*strength);
comp_22=`
comp_23=`// ***** :)
comp_24=`
comp_25=`uv = uv_mirror;
comp_26=`
comp_27=`
comp_28=`    float2 sam = tex2D(sampler_fc_main, uv);
comp_29=`    ret = tex2D(sampler_fc_main, float2(uv.x*1.12, uv.y));
comp_30=`    sam -= GetBlur3(uv)-GetBlur1(uv_orig)*1;       
comp_31=`    sam *=0.1;
comp_32=`
comp_33=`    //sam affects how the fire moves
comp_34=`    float3 reta = tex2D(sampler_main, float2(uv.x+sam.x, uv.y-sam.y) ).xyz;
comp_35=`    ret = reta.x * reta * (reta.x)*ret;
comp_36=`    ret = lerp(ret*float3(0.3,0.1,0.1), ret, q12);
comp_37=`
comp_38=`    ret *= 2; //gamma
comp_39=`    //ret *= ret; //darken
comp_40=`
comp_41=`}
