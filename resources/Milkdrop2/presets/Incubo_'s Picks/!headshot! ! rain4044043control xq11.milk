wave_1_per_point9=i=t8; is=i+.5; num=num_inst; 
wave_1_per_point10=//sample=(is)/num; 
wave_1_per_point11=srot=sample*2-1;tample=(sample+reg17)-int(sample+reg17);trot=tample*2-1;
wave_1_per_point12=frmc+=if(equal(frmc,num),-num,1);frmc=min(frmc,num); iq=band(i,band(i+1,band(i+2,band(i-7,band(i-3,band(i+3,i+3))))));//*bor(i+2)+(i+3)+(i+4)+(i+5);
