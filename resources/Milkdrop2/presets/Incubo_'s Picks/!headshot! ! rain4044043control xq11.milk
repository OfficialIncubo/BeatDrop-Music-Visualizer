wave_1_per_point16=//additive=.1-int((is/(num-rand(t2/2))+tsvar));
wave_1_per_point17=ytrip+=5; ytrip-=int(ytrip);ytrap+=5; ytrap-=int(ytrip);
wave_1_per_point18=ytip+=5; ytip-=int(ytrip);ytop+=5; ytop-=int(ytrip);
wave_1_per_point19=yt=(max(ytrap,ytop)+(max(ytip,ytrip)))/4;
