wave_1_per_point22=//b=chsn;b2=1-chsn;
wave_1_per_point23=//border_a=rx2*.0000001;
wave_1_per_point24=a=(.6+(.3*abs(x2*2-1)));
wave_1_per_point25=//a2=a*.03;
wave_1_per_point26=x2=.78*sin(trot*pi2)+(.5)*cos(ewq2);
wave_1_per_point27=rx2=((ewq2*(bass_att-bass))*pi2)*.16*sin(time); x2=rx2+x2*.5;
wave_1_per_point28=dro=-time/t4;reg34=drop*vol*(1-y*(x-.5+bal));
wave_1_per_point29=y2=0+.25*sin(var1a+pvar)+.01*cos(tsvar)+(reg34*-qz);
wave_1_per_point30=y2=y2*(1-.3*abs(qx))+srot*sin(ewq1);
wave_1_per_point31=x=x2*(.6+(abs(qy)*0.9)*sin(time*sample))+.5;
wave_1_per_point32=y=y2*1+(3*qz*qxp)+.5-(r+r*sin(ytrip-g));
wave_1_per_point33=xr=9/(1024/num);xr*=if(below(xr,4),1.3,if(below(xr,3),1.8,if(below(xr,2),2.8,if(below(xr,1),17.2,1))));
