wave_1_per_frame1=//tm = time*.1;t1 = t1*sin(tm*t4) + (1-t1)*sin(tm*t7);t2 = t2*sin(tm*t5) + (1-t2)*sin(tm*t8);t3 = t3*sin(tm*t6) + (1-t3)*sin(tm*1);
wave_1_per_frame2=
wave_1_per_frame3=//tic = min(time - tin,1);tin = time;tva = (tic*q1*.5);tvb = (tic*q2*.5);tvc = (tic*q3*.5);q1 = tva;q2 = tvb;q3 = tvc;sz = .5;len = 1;t4 = len;
wave_1_per_frame4=
