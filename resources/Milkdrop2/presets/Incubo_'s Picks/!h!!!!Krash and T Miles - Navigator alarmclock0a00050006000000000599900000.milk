wave_1_per_point26=x2=.78*sin(trot*pi2)+(.5)*cos(ewq2);
wave_1_per_point27=rx2=((ewq2*(bass_att-bass))*pi2)*.16*sin(time); x2=rx2+x2*.5;
wave_1_per_point28=dro=-time/t4;reg34=drop*vol*(1-y*(x-.5+bal));
wave_1_per_point29=y2=0+.25*sin(var1a+pvar)+.01*cos(tsvar)+(reg34*-qz);
