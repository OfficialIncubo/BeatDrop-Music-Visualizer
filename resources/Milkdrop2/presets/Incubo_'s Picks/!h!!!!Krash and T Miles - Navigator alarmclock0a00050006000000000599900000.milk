wave_1_per_frame1=//tm = time*.1;t1 = t1*sin(tm*t4) + (1-t1)*sin(tm*t7);t2 = t2*sin(tm*t5) + (1-t2)*sin(tm*t8);t3 = t3*sin(tm*t6) + (1-t3)*sin(tm*1);
