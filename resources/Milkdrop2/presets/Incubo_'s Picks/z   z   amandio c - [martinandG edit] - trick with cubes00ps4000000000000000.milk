wave_3_per_frame1=samples=reg28/2;t8=samples;
wave_3_per_point1=//num_inst=256+t6+(time-t7)/fps;
wave_3_per_point2=//num_inst=int(num_inst/162)*162;t8=num_inst;
wave_3_per_point3=//num_inst=t8;
wave_3_per_point4=bal=value2-value1;
wave_3_per_point5=qx=x-.5+bal;qy=y-.5;
wave_3_per_point6=rr=atan2(-qx,-qy);
wave_3_per_point7=dd=sqrt(sqr(qx)+sqr(qy));
wave_3_per_point8=pie=q23; tau=q26;
wave_3_per_point9=i=int(sample*t8);   num=t8/2;
wave_3_per_point10=sa=1-(sample);     
wave_3_per_point11=qnums=num/162;
wave_3_per_point12=qgroups=(num/6);        
wave_3_per_point13=sa1=((i/qgroups)%6)/qnums;   t1=tau*sa1 + q1 ;         //// circle of 6 cubes on zplane
wave_3_per_point14=z1=.1+.07*sin(.3*q1) + i/num*.6;;
wave_3_per_point15=x1 = z1*sin(t1)*sin(.5*q1);    y1 = z1*cos(t1*1.1);     
wave_3_per_point16=w=atan2(y1,x1) + q3*.32;
wave_3_per_point17=
wave_3_per_point18=vz=(num/6/6/3/3);vy=(num/6/6/3); vx=(num/6/6);
wave_3_per_point19=x20=((i/6)%vx)/vx;   y20=((i/6)%vy)/vy;     z20=((i/6)%vz)/vz;       ///// 3x3x3 mesh
wave_3_per_point20=x2 =  .4*x20 -  y20 +  .7*z20;
wave_3_per_point21=y2 =  1.2*sin(time)*x20 - 1.3*cos(time*.4)*y20 - 1.7*sin(time*1.2)*z20;     
wave_3_per_point22=t2=w;   
wave_3_per_point23=mx2=x2*sin(t2)+y2*cos(t2);    
wave_3_per_point24=my2=y2*sin(t2)-x2*cos(t2);
wave_3_per_point25=z2=.7*z1;      
wave_3_per_point26=x2=mx2*z2;    y2=my2*z2;
wave_3_per_point27=
wave_3_per_point28=
wave_3_per_point29=t3 = (num/6)*tau*sa +.5*sa +q1 ;               //// cubes made of 6 triangles
wave_3_per_point30=z3 = .13*z2;
wave_3_per_point31=x3 = z3*sin(t3);    y3 = z3*cos(t3);     
wave_3_per_point32=
wave_3_per_point33=
wave_3_per_point34=
wave_3_per_point35=x=.5 + (x1+x2+x3)/q6;    y=.5 + (y1+y2+y3); 
wave_3_per_point36=
wave_3_per_point37=rad = 2*z3;     ang=pie/4+t3;
wave_3_per_point38=
wave_3_per_point39=t1=.5+.4*sin(1.57*3*y20); 
wave_3_per_point40=
wave_3_per_point41=//r=x3*1-(qx-qy*(.5*(1-dd+.5)));// r=max(r*x3,x3*(1-r));
wave_3_per_point42=r=rad*(rr-dd*(qx+qy+.5))*qx+(.5*x/i);
wave_3_per_point43=//r*=abs(x3)+qy+qx-x3*2;
wave_3_per_point44=r*=(i/2)%3; r-=int(r);r=max(1-r,r);
wave_3_per_point45=
wave_3_per_point46=g=r*(.4+.02*((rr-ang)/(tau+ang-pie)))*abs(r-(dd*max(qx,qy)));                      
wave_3_per_point47=b=r*dd+(.3*g)-ang/rr; //a=g-max(g*b,r*g)*.2;
wave_3_per_point48=//
wave_3_per_point49=r2=abs(r);g2=abs(g);b2=abs(b);
wave_3_per_point50=r2-=int(r2);g2-=int(g2);b2-=int(b2);
wave_3_per_point51=r=r2;g=g2;b=b2;
wave_3_per_point52=//r=r;border_g=g;border_b=b;
wave_3_per_point53=a=rad*(1/(ang-r-g+sample));//a2=1;border_a=1-above(g,(b+r)/2);
wave_3_per_point54=//g*=1-border_a;
wave_3_per_point55=//tex_ang-=ang;
wave_3_per_point56=//tex_zoom=tex_zoom+rad*1.2;
wave_3_per_point57=reg88=q28;
wave_3_per_point58=
wave_3_per_point59=
wave_3_per_point60=x+=5+bal;y+=5+value1+value2;x-=int(x);y-=int(y);
