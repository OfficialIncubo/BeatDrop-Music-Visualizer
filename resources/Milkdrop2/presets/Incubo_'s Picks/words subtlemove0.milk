per_frame_1=wave_r = if(above(frame%2,0),.7+.3*cos(time*.99),.7+.3*sin(time*.99));
per_frame_2=wave_g =if(above(frame%2,0),.6+.3*cos(time*1.66)+.1*cos(time),.6+.3*sin(time*1.66)+.1*sin(time));
per_frame_3=wave_b =if(above(frame%2,0),.6+.4*cos(time*2)+.2*cos(time),.6+.4*sin(time*2)+.2*sin(time));
per_frame_4=wave_mystery = .2+.4*sin(time);
per_frame_5=wave_mode = if(above(frame%2,0),1,2);
per_pixel_1=zoom = if(above(rad*bass,.3),0|bass,.99);
per_pixel_2=rot = -ang*.5+time;
warp_1=`sampler sampler_fw_rand07;
warp_2=`shader_body
warp_3=`{
warp_4=`    // sample previous frame
warp_5=`    ret = tex2D( sampler_main, uv ).z;
warp_6=`    
warp_7=`    // darken (decay) over time
warp_8=`    ret *= 0.999; //or try: ret -= 0.004;
warp_9=`ret = tex2d(sampler_fw_rand07, uv);
warp_10=`}
comp_1=`shader_body
comp_2=`{
comp_3=`  float2 uv_flipped = float2(1 - uv.x,uv.y);    // '1' auto-replicates to float2(1,1)
comp_4=`            ret = max( tex2D(sampler_main, uv).xyz, 
comp_5=`                       tex2D(sampler_main, uv_flipped).xyz );
comp_6=`            ret = pow(ret, float3(.88+0.5*(bass-bass_att*treb_att)*sin(time*0.15), 1.12+0.5*(bass-bass_att*mid_att)*sin(time*0.13),1+0.5*(bass-bass_att*treb_att)*sin(time*0.12))); 
comp_7=`ret=1-ret;}
