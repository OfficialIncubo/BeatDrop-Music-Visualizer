shape_0_init1=t7=time;t6=22/7;t8=2*t6;
shape_0_per_frame1=sample=instance/num_inst;
shape_0_per_frame2=border_r=0.2 * bass;
shape_0_per_frame3=border_g=border_g * mid;
shape_0_per_frame4=border_b=border_b * treb;
shape_0_per_frame5=border_a=border_a + 0.3*tan(time);
shape_0_per_frame6=q17=time-t7; q18=((q17*.5/t6)-int(q17*.5/t6))*(t8*1+rad);
shape_0_per_frame7=x=x + (x*bass)*.25;
shape_0_per_frame8=additive=above(instance,num_inst-(num_inst-2));
shape_0_per_frame9=y=y + (y*treb)*0.25;
shape_0_per_frame10=sides+=q18*(2.5+sample)-num_inst+instance;
shape_0_per_frame11=ang=ang +1/fps+ ((ang*mid)-(ang*treb)-ang*bass);
shape_0_per_frame12=tex_ang=ang/t8 = ang*sin(q1*1.3/-q18);
shape_0_per_frame13=rad=rad + rad*((mid_att+bass_att+treb_att*(1-.2*sample))*0.33);
shape_0_per_frame14=tex_zoom=tex_zoom -(rad*.732)*cos((.5+(.5*1/sides)));
shape_0_per_frame15=r2*=1-sample; r*=sample;
shape_0_per_frame16=a=(sample+.2);a2=.5-(a+.2*sample);
shape_0_per_frame17=a=a-int(a);a2=a2-int(a2);
shape_0_per_frame18=rad*=(.27+.135*(sample*2-1));
shape_0_per_frame19=y=y-.32*(1/num*((1-sample)*(max(0,(above(mid,max(.6,mid_att))*treb)-.5))));
shape_0_per_frame20=y+=5.5; y-=int(y);a=.25*max(a,1-a);
shape_0_per_frame21=border_a=.1*sample;
