shape_0_per_frame1=x = 0.5 + 0.2*sin(time*0.4 + instance*2.094) + 0.05*bass*sin(time*1.1 + instance*0.7);
shape_0_per_frame2=y = 0.5 + 0.2*cos(time*0.3 + instance*2.094) + 0.05*bass*cos(time*0.8 + instance*0.9);
shape_0_per_frame3=rad = 0.03 + bass_att*0.05;
shape_0_per_frame4=a = 0.3 + bass*0.7;
shape_0_per_frame5=a2 = a*0.4;
shape_0_per_frame6=border_a = 0.05 + bass*0.3;
