per_frame_1=mv_r = mv_r + 0.2*( 0.60*sin(0.980*time) + 0.40*sin(1.047*time) );
per_frame_2=mv_g = mv_g + 0.2*( 0.60*sin(0.835*time) + 0.40*sin(1.081*time) );
per_frame_3=mv_b = mv_b + 0.2*( 0.60*sin(0.814*time) + 0.40*sin(1.011*time) );
per_frame_4=q1 = (cx*2-1) + 0.6*( 0.60*sin(0.374*time) + 0.40*sin(0.294*time) );
per_frame_5=q2 = (cy*2-1) + 0.6*( 0.60*sin(0.393*time) + 0.40*sin(0.223*time) );
per_frame_6=ob_r = 1- 0.4*abs(q1);
per_frame_7=ob_g = 0.3*abs(q2);
per_frame_8=ob_b = 0.4*abs(q1);
per_frame_9=wave_x = 1-abs(q2)-0.05;
per_frame_10=wave_y = 1-abs(q1)-0.06;
per_frame_11=wave_r = wave_r + 0.4*( 0.60*sin(0.514*time) + 0.40*sin(1.211*time) );
per_frame_12=wave_b = wave_b + 0.4*( 0.60*sin(0.714*time) + 0.40*sin(q2) );
per_frame_13=wave_g = wave_g + 0.4*( 0.60*sin(10*q1) + 0.40*sin(10*q2) );
per_pixel_1=du = (x*2-1) - q1;
per_pixel_2=dv = (y*2-1) - q2;
per_pixel_3=dist = sqrt(du*du+dv*dv);
per_pixel_4=ang2 = atan2(du,dv) + time*0.15;
per_pixel_5=mult = -0.2*sin(dist*0.05);
per_pixel_6=dx = mult*sin(ang2*2-1.5)*aspectx;
per_pixel_7=dy = mult*cos(ang2*2-1.5)*aspecty;
warp_1=`sampler sampler_rand00; 
warp_2=`
warp_3=`shader_body
warp_4=`{
warp_5=`    // sample previous frame    
warp_6=`   // ret = tex2D( sampler_pc_main, float2(uv.x+0.003, uv.y)).xyz;
warp_7=`  float2 m = floor(frac(uv*0.5)*2);
warp_8=`  uv = frac(uv)*(1-m) + (m)*frac(1-uv);
warp_9=`  ret = lerp(tex2D( sampler_rand00 , float2(uv.x+0.003, uv.y)).xyz, tex2D( sampler_pc_main, float2(uv.x*q17, uv.y*q18)),GetPixel(uv).z-.53*sin(q19));
warp_10=`  ret -= tex2D( sampler_rand00,uv).z;
warp_11=`  
warp_12=`  uv *=2 ;
warp_13=`    
warp_14=`    // darken (decay) over time
warp_15=`    ret *= 1;
warp_16=`}
comp_1=`sampler sampler_rand00; 
comp_2=`
comp_3=`
comp_4=`shader_body
comp_5=`{
comp_6=`    float2 d = texsize.zw*5;
comp_7=`    float3 dx = ( GetBlur1(uv+float2(1,0)*d)-GetBlur1(uv-float2(1,0)*d) );
comp_8=`    float3 dy = ( GetBlur1(uv+float2(0,1)*d)-GetBlur1(uv-float2(0,1)*d) );
comp_9=`float2 uv1 = uv - float2(dx.y,dy.y)*0.2;
comp_10=`ret = GetBlur1(uv1).y*0.75 + ((-dx+dy).y+0.5)*0.25;
comp_11=`
comp_12=`float2 c = 0.5;
comp_13=`float2 uv2 = c + (uv-c)*(1-bass_att*0.04) - float2(dy.y,-dx.y)*texsize.zw*16 - float2(dx.x,dy.y)*texsize.zw*8 + float2(1,-1)*texsize.zw*16;
comp_14=`ret = lerp(ret,0,saturate(GetBlur1(uv).z*1.2));
comp_15=`ret = lerp(ret,ret*float3(2,1,0),GetPixel(uv).z*3);
comp_16=`ret = lerp(ret*float3(1,1,1),float3(0,-0.2,-1),GetBlur1(uv2).x*2.4);
comp_17=`float2 uv3 = uv + float2(dx.x,dy.x)*texsize.zw*6 + float2(-dy.z,dx.z)*texsize.zw*24;
comp_18=`float2 uv31 = uv + float2(dx.x,dy.x)*texsize.zw*6 - float2(-dy.z,dx.z)*texsize.zw*24;
comp_19=`float x = max(GetPixel(uv3).x,GetPixel(uv31).x)*.5;
comp_20=`
comp_21=`
comp_22=`ret = lerp(ret*.47,tex2D(sampler_rand00, uv).xyz, x*.5+.15*sin(time/(4*bass_att)));
comp_23=`
comp_24=`//ret = lerp(ret,float3(0,0.5,1)*(0.9+(-dx+dy).x),x);
comp_25=`//ret = GetPixel(uv).z;
comp_26=`float3 uv_sphere;
comp_27=`uv_sphere.xy = uv;
comp_28=`uv_sphere.xy = frac( uv_sphere.xy  ) * 2.0;
comp_29=`uv_sphere.xy = 1.0 - abs( uv_sphere.xy - 1.0 );
comp_30=`uv_sphere = tex2Dbias( sampler_main, float4(uv_sphere.xy,0.0,-0.5) );
comp_31=`ret += uv_sphere;
comp_32=`
comp_33=`ret =min(ret,.79);
comp_34=`}
