shape_3_init1=ang=1-ang;
shape_3_per_frame1=ang =((mid_att + treb -bass_att) + (treb_att + mid -bass*instance))*sin(time*0.3)*0.03;
shape_3_per_frame2=//tex_ang=1- (ang*0.1);
shape_3_per_frame3=//tex_zoom=0.02 +ang*instance;
per_frame_init_1=// A grayish blob
per_frame_init_2=// 2007.02.01 - raron
per_frame_init_3=
per_frame_init_4=q1 = 0.4;
per_frame_init_5=q2 = 0.4;
per_frame_init_6=
per_frame_init_7=q16=22/7;
per_frame_1=q3 = 32 + 32 * cos(time * 4);
per_frame_2=q4 = 2 + 24 * sin(time* 1.4);
per_frame_3=q5 = 32 - 32 * sin(time * 2.1);
per_frame_4=q6 = 24 + 24 * cos(time * 1.3);
per_frame_5=bhit=above(bass,bass_att);
per_frame_6=bs=bass_att*(1-.3*bhit)+(.3*bass*bhit);
per_frame_7=mhit=above(mid,mid_att);
per_frame_8=ms=mid_att*(1-.3*mhit)+(.3*mid*mhit);
per_frame_9=pie=q16;pi2=2*pie;;lfo=lft*.01;
per_frame_10=lft=(time*3+bs+ms)/pi2;
per_frame_11=lfos=sin(lfo); lfoc=cos(lfo);
per_frame_12=q12=lfos; q13=lfoc;
per_frame_13=zoom = 0.9 + bs * 0.05;
per_frame_14=rot = 0.2 *ms- 0.2 * bs;
per_pixel_1=qx=x-.5; qy=y-.5; aqrad=((rad +.1*q12)*2-1); qrad=aqrad*if(below(aqrad,0),.1,1); zoom = zoom *.9+ (qrad*2-1)* 0.41;
per_pixel_2=rot-=zoom;
warp_1=`sampler sampler_fw_rand07;
warp_2=`shader_body
warp_3=`{
warp_4=`    // sample previous frame
warp_5=`    ret = tex2D( sampler_main, uv ).z;
warp_6=`    
warp_7=`    // darken (decay) over time
warp_8=`    ret *= 0.999; //or try: ret -= 0.004;
warp_9=`ret = tex2d(sampler_fw_rand07, uv);
warp_10=`}
comp_1=`shader_body
comp_2=`{
comp_3=`
comp_4=`
comp_5=`
comp_6=`
comp_7=`// ***** Martin's ripples on water surface code, parameterized by Flexi *****
comp_8=`
comp_9=`float h = q9;                      // height of the horizon
comp_10=`float cut_off = 0.0;              // cut off lower border
comp_11=`float2 t = float2(0.1,-0.05)*time;  // velocity
comp_12=`float strength = 0.025;
comp_13=`
comp_14=`
comp_15=`float2 c = uv_orig-float2(0.5,1-h);
comp_16=`float z = 3/c.y;
comp_17=`float2 uv_water = float2(c.x*z*h,z*h)*0.05+t;
comp_18=`int mask = (c.y>0);
comp_19=`uv_water = (tex2D(sampler_noise_hq,uv_water)-0.5)*mask;
comp_20=`float2 uv_mirror = 1.0-abs(frac((c+float2(0.5,1))*0.5)*2-1)+float2(0,-cut_off);
comp_21=`uv_mirror =frac(uv_mirror-uv_water.xy*strength);
comp_22=`
comp_23=`// ***** :)
comp_24=`
comp_25=`uv = uv_mirror;
comp_26=`
comp_27=`
comp_28=`    float2 sam = tex2D(sampler_fc_main, uv);
comp_29=`    ret = tex2D(sampler_fc_main, float2(uv.x*1.12, uv.y));
comp_30=`    sam -= GetBlur3(uv)-GetBlur1(uv_orig)*1;       
comp_31=`    sam *=0.1;
comp_32=`
comp_33=`    //sam affects how the fire moves
comp_34=`    float3 reta = tex2D(sampler_main, float2(uv.x+sam.x, uv.y-sam.y) ).xyz;
comp_35=`    ret = reta.x * reta * (reta.x)*ret;
comp_36=`    ret = lerp(ret*float3(0.3,0.1,0.1), ret, q12);
comp_37=`
comp_38=`    ret *= 2; //gamma
comp_39=`    //ret *= ret; //darken
comp_40=`
comp_41=`}
