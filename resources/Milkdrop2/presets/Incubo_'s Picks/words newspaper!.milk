shape_1_init1=x=1.210*x; y=1.12*y; rad=0.72;
shape_1_init2=
shape_1_init3=t3=1+(x*0.7)+(y*0.5) + 1-(rad+y)*0.018;
shape_1_init4=t4=0.17*sin(time*0.02);
shape_1_init5=
shape_1_init6=t1=x; t2=y;
shape_1_per_frame1=ang = ang + (bass*.2) *sin(time*.4+t10)*0.5;
shape_1_per_frame2=rad = rad + 0.46*cos(time*ang)*0.05 + 1*(0.71-x)*sin(time*0.014);
shape_1_per_frame3=//y=y+t10;
shape_1_per_frame4=//num_inst = num_inst  + 24*sin((0.35*time)*mid);
shape_1_per_frame5=r=r*bass;
shape_1_per_frame6=g=g*treb;
shape_1_per_frame7=b=b*mid;
shape_1_per_frame8=r2=1-g;
shape_1_per_frame9=g2=1-b;
shape_1_per_frame10=b2=1-r;
shape_1_per_frame11=//x =x + (sin(time)*0.090+0.5);
shape_1_per_frame12=//y = y + (sin(time/5)*0.090+0.5)-y;
