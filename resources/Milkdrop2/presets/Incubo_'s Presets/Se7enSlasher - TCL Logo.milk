MILKDROP_PRESET_VERSION=201
PSVERSION=2
PSVERSION_WARP=2
PSVERSION_COMP=0
[preset00]
fRating=3.000
fGammaAdj=2.000
fDecay=0.980
FFTAttack=0.500
FFTDecay=0.700
fVideoEchoZoom=2.000
fVideoEchoAlpha=0.500
nVideoEchoOrientation=0
nWaveMode=0
bAdditiveWaves=0
bWaveDots=0
bWaveThick=0
bModWaveAlphaByVolume=0
bMaximizeWaveColor=1
bTexWrap=1
bDarkenCenter=0
bRedBlueStereo=0
bBrighten=0
bDarken=0
bSolarize=0
bInvert=0
fWaveAlpha=0.800
fWaveScale=1.000
fWaveSmoothing=0.750
fWaveParam=0.000
fModWaveAlphaStart=0.750
fModWaveAlphaEnd=0.950
fWarpAnimSpeed=1.000
fWarpScale=1.000
fZoomExponent=1.00000
fShader=0.000
zoom=1.00000
rot=0.00000
cx=0.500
cy=0.500
dx=0.00000
dy=0.00000
warp=1.00000
sx=1.00000
sy=1.00000
wave_r=0.000
wave_g=0.000
wave_b=0.000
wave_x=0.000
wave_y=0.000
ob_size=0.010
ob_r=0.000
ob_g=0.000
ob_b=0.000
ob_a=0.000
ib_size=0.010
ib_r=0.250
ib_g=0.250
ib_b=0.250
ib_a=0.000
nMotionVectorsX=12.000
nMotionVectorsY=9.000
mv_dx=0.000
mv_dy=0.000
mv_l=0.900
mv_r=1.000
mv_g=1.000
mv_b=1.000
mv_a=0.000
b1n=0.000
b2n=0.000
b3n=0.000
b1x=1.000
b2x=1.000
b3x=1.000
b1ed=0.250
per_frame_1=warp=0;
per_frame_2=bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);
per_frame_3=
per_frame_4=echo_zoom = bass_thresh-0.3;
per_frame_5=echo_alpha = 1+bass_thresh;
warp_1=`sampler sampler_fc_tcl_logo;
warp_2=`float4 texsize_tcl_logo; // .xy = (w,h); .zw = (1/w, 1/h)
warp_3=`
warp_4=`// Deepseek - Universal edge fading function
warp_5=`// Modified EdgeFade function - fades top, left, and right edges only
warp_6=`float EdgeFade(float2 uva, float margin)
warp_7=`{
warp_8=`    margin = max(margin, 0.001); // Minimum margin to prevent artifacts.
warp_9=`    // Fade left/right edges
warp_10=`    float fadeX = smoothstep(0.0, margin, uva.x) * smoothstep(1.0, 1.0 - margin, uva.x);
warp_11=`    // Fade top/bottom edges
warp_12=`    float fadeY = smoothstep(0.0, margin, uva.y) * smoothstep(1.0, 1.0 - margin, uva.y);
warp_13=`    return fadeX * fadeY;
warp_14=`}
warp_15=`
warp_16=`shader_body
warp_17=`{
warp_18=`    float2 uvi = uv*5-2;
warp_19=`    float edgefade = EdgeFade(uvi, .01);
warp_20=`    // sample previous frame
warp_21=`    ret = tex2D(sampler_fc_tcl_logo, uvi).xyz * edgefade;
warp_22=`    ret *= 1;
warp_23=`}
