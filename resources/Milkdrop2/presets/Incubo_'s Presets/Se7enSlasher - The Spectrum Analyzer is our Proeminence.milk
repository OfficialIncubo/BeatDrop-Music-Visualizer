MILKDROP_PRESET_VERSION=201
PSVERSION=4
PSVERSION_WARP=4
PSVERSION_COMP=2
[preset00]
fRating=5.000
fGammaAdj=1.200
fDecay=0.950
FFTAttack=0.500
FFTDecay=0.650
fVideoEchoZoom=1.000
fVideoEchoAlpha=0.000
nVideoEchoOrientation=0
nWaveMode=15
bAdditiveWaves=0
bWaveDots=0
bWaveThick=0
bModWaveAlphaByVolume=0
bMaximizeWaveColor=0
bTexWrap=1
bDarkenCenter=0
bRedBlueStereo=0
bBrighten=1
bDarken=0
bSolarize=0
bInvert=0
fWaveAlpha=0.000
fWaveScale=0.010
fWaveSmoothing=0.000
fWaveParam=0.000
fModWaveAlphaStart=0.000
fModWaveAlphaEnd=0.000
fWarpAnimSpeed=2.500
fWarpScale=2.000
fZoomExponent=1.00000
fShader=1.000
zoom=1.00000
rot=0.00000
cx=0.500
cy=0.500
dx=0.00000
dy=0.00000
warp=0.00000
sx=1.00000
sy=1.00000
wave_r=0.000
wave_g=0.000
wave_b=0.000
wave_x=0.500
wave_y=0.500
ob_size=0.000
ob_r=0.000
ob_g=0.000
ob_b=0.000
ob_a=0.000
ib_size=0.000
ib_r=0.000
ib_g=0.000
ib_b=0.000
ib_a=0.000
nMotionVectorsX=0.000
nMotionVectorsY=0.000
mv_dx=0.000
mv_dy=0.000
mv_l=0.000
mv_r=0.000
mv_g=0.000
mv_b=0.000
mv_a=0.000
b1n=0.000
b2n=0.000
b3n=0.000
b1x=1.000
b2x=1.000
b3x=1.000
b1ed=0.250
warp_1=`// Preset generated by DeepSeek, modified by me
warp_2=`
warp_3=`#define NUM_BARS 48.0
warp_4=`#define BAR_SPACING 0.015
warp_5=`#define HEIGHT_SCALE 2.5
warp_6=`#define DISPLACE_STRENGTH 0.3
warp_7=`#define ROTATION_SPEED 0.2
warp_8=`
warp_9=`// Sample random texture for displacement
warp_10=`uniform sampler sampler_rand00;
warp_11=`
warp_12=`float3 hsv2rgb(float3 c) {
warp_13=`    float4 K = float4(1.0, 2.0/3.0, 1.0/3.0, 3.0);
warp_14=`    float3 p = abs(frac(c.xxx + K.xyz) * 6.0 - K.www);
warp_15=`    return c.z * lerp(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
warp_16=`}
warp_17=`
warp_18=`// 3D rotation matrix
warp_19=`float3 rotateY(float3 v, float angle) {
warp_20=`    float c = cos(angle);
warp_21=`    float s = sin(angle);
warp_22=`    return float3(v.x * c - v.z * s, v.y, v.x * s + v.z * c);
warp_23=`}
warp_24=`
warp_25=`shader_body
warp_26=`{
warp_27=`    // Original UV for random sampling
warp_28=`    float2 uv_orig_local = uv_orig;
warp_29=`
warp_30=`    
warp_31=`    // Setup 3D perspective
warp_32=`    float aspect = texsize.x / texsize.y;
warp_33=`    float2 uv_centered = (uv_orig_local * 2.0 - 1.0) * float2(aspect, 1.0);
warp_34=`    
warp_35=`    // Rotation over time
warp_36=`    float rot_angle = time * ROTATION_SPEED;
warp_37=`    
warp_38=`    // Create 3D bar positions
warp_39=`    float3 color = float3(0.0, 0.0, 0.0);
warp_40=`    
warp_41=`    // Calculate bar dimensions
warp_42=`    float total_unit = 1.0 / NUM_BARS;
warp_43=`    float actual_bar_width = total_unit - BAR_SPACING;
warp_44=`    
warp_45=`    // Frequency mapping
warp_46=`    float bass_freq = 50.0;
warp_47=`    float mid_freq = 500.0;
warp_48=`    float treble_freq = 5000.0;
warp_49=`    
warp_50=`    // Get FFT values for displacement strength
warp_51=`    float bass_fft = get_fft_hz(bass_freq);
warp_52=`    float mid_fft = get_fft_hz(mid_freq);
warp_53=`    float treble_fft = get_fft_hz(treble_freq);
warp_54=`    
warp_55=`    // Sample random texture for each frequency band
warp_56=`    float2 rand_coord = uv_orig_local;
warp_57=`    float rand_bass = tex2D(sampler_rand00, rand_coord).r;
warp_58=`    float rand_mid = tex2D(sampler_rand00, rand_coord).g;
warp_59=`    float rand_treble = tex2D(sampler_rand00, rand_coord).b;
warp_60=`    
warp_61=`    // Combined displacement strength per frequency
warp_62=`    float bass_displace = bass_fft * DISPLACE_STRENGTH * rand_bass;
warp_63=`    float mid_displace = mid_fft * DISPLACE_STRENGTH * rand_mid;
warp_64=`    float treble_displace = treble_fft * DISPLACE_STRENGTH * rand_treble;
warp_65=`    
warp_66=`    // Render bars
warp_67=`    for (float i = 0.0; i < NUM_BARS; i += 1.0) {
warp_68=`        float bar_index = i;
warp_69=`        float t_pos = bar_index / NUM_BARS;
warp_70=`        
warp_71=`        // Get FFT value for this bar (log-spaced)
warp_72=`        float log_min = log(30.0);
warp_73=`        float log_max = log(16000.0);
warp_74=`        float freq = exp(lerp(log_min, log_max, t_pos));
warp_75=`        float fft_val = get_fft_hz(freq) * HEIGHT_SCALE;
warp_76=`        
warp_77=`        // Bar position in 3D space
warp_78=`        float bar_x = (bar_index * total_unit + actual_bar_width * 0.5) * 2.0 - 1.0;
warp_79=`        bar_x *= aspect;
warp_80=`        
warp_81=`        // Apply frequency-specific displacement to X position
warp_82=`        float displace_x = 0.0;
warp_83=`        if (freq < 200.0) displace_x = bass_displace;
warp_84=`        else if (freq < 2000.0) displace_x = mid_displace;
warp_85=`        else displace_x = treble_displace;
warp_86=`        
warp_87=`        bar_x += displace_x * (rand_bass - 0.5) * 2.0;
warp_88=`        
warp_89=`        // Bar height
warp_90=`        float bar_h = fft_val;
warp_91=`        
warp_92=`        // Create 3D bar with depth
warp_93=`        float bar_z = bar_index / NUM_BARS * 2.0 - 1.0;
warp_94=`        
warp_95=`        // Apply mid-frequency displacement to Z
warp_96=`        bar_z += mid_displace * (rand_mid - 0.5) * 2.0;
warp_97=`        
warp_98=`        float3 bar_pos = float3(bar_x, 0.0, bar_z);
warp_99=`        
warp_100=`        // Rotate the entire scene
warp_101=`        bar_pos = rotateY(bar_pos, rot_angle);
warp_102=`        
warp_103=`        // Project to 2D
warp_104=`        float dist = 2.5;
warp_105=`        float2 screen_pos = bar_pos.xy / (bar_pos.z + dist);
warp_106=`        
warp_107=`        // Bar dimensions in screen space
warp_108=`        float bar_screen_width = actual_bar_width * aspect / (bar_pos.z + dist);
warp_109=`        float bar_screen_height = bar_h / (bar_pos.z + dist);
warp_110=`        
warp_111=`        // Check if pixel is inside bar
warp_112=`        float dx = abs(uv_centered.x - screen_pos.x);
warp_113=`        float dy = abs(uv_centered.y - screen_pos.y);
warp_114=`        
warp_115=`        float bar_mask = 1.0 - step(bar_screen_width * 0.5, dx);
warp_116=`        bar_mask *= 1.0 - step(bar_screen_height * 0.5, dy);
warp_117=`        
warp_118=`        // Apply treble displacement to vertical glow
warp_119=`        float glow_y = treble_displace * rand_treble * 2.0;
warp_120=`        
warp_121=`        float hue;
warp_122=`        if (bar_mask > 0.0) {
warp_123=`            // Color based on frequency
warp_124=`            hue = t_pos + time * 0.1;
warp_125=`            float3 bar_color = hsv2rgb(float3(hue, 0.9, 1.0));
warp_126=`            
warp_127=`            // Add brightness based on distance
warp_128=`            float brightness = 1.0 / (1.0 + abs(bar_pos.z) * 0.5);
warp_129=`            color += bar_color * bar_mask * brightness;
warp_130=`        }
warp_131=`        
warp_132=`        // Add glow effect (displaced by treble)
warp_133=`        float glow_dist = length(float2(dx, dy + glow_y));
warp_134=`        float glow = exp(-glow_dist * 8.0) * fft_val * 0.3;
warp_135=`        float3 glow_color = hsv2rgb(float3(hue, 0.8, 1.0));
warp_136=`        color += glow_color * glow;
warp_137=`    }
warp_138=`    
warp_139=`    // Gamma correction
warp_140=`    color = pow(color, 1.0 / 2.2);
warp_141=`    
warp_142=`    ret = float4(color, 1.0);
warp_143=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    ret = tex2D(sampler_main, uv).xyz;
comp_4=`    
comp_5=`    // Slight brightness boost
comp_6=`    ret *= 1.2;
comp_7=`}
