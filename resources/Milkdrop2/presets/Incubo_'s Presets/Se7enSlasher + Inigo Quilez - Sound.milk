fVideoEchoZoom=1.007
fVideoEchoAlpha=0.500
nVideoEchoOrientation=2
nWaveMode=15
bAdditiveWaves=1
bWaveDots=0
bWaveThick=1
bModWaveAlphaByVolume=0
bMaximizeWaveColor=1
bTexWrap=1
bDarkenCenter=0
bRedBlueStereo=0
bBrighten=1
bDarken=1
bSolarize=0
bInvert=0
fWaveAlpha=0.000
fWaveScale=0.625
fWaveSmoothing=0.900
fWaveParam=0.000
fModWaveAlphaStart=0.880
fModWaveAlphaEnd=1.980
fWarpAnimSpeed=0.010
fWarpScale=0.010
fZoomExponent=1.00000
fShader=1.000
zoom=1.00000
rot=0.00000
cx=0.500
cy=0.500
dx=0.00000
dy=0.00000
warp=0.00000
sx=1.00000
sy=1.00000
wave_r=0.000
wave_g=0.000
wave_b=0.000
wave_x=0.500
wave_y=0.500
ob_size=0.500
ob_r=0.010
ob_g=0.000
ob_b=0.000
ob_a=0.000
ib_size=0.260
ib_r=0.235
ib_g=0.250
ib_b=0.250
ib_a=0.000
nMotionVectorsX=64.000
nMotionVectorsY=48.000
mv_dx=0.000
mv_dy=0.000
mv_l=1.000
mv_r=1.060
mv_g=1.000
mv_b=0.819
mv_a=0.000
b1n=0.000
b2n=0.000
b3n=0.000
b1x=1.000
b2x=1.000
b3x=1.000
b1ed=0.250
warp_1=`/*
warp_2=`Sound by Inigo Quilez
warp_3=`Converted to MilkDrop by me (no AI, hand-written)
warp_4=`Original ShaderToy shader link: https://www.shadertoy.com/view/Xds3Rr
warp_5=`*/
warp_6=`
warp_7=`shader_body {
warp_8=`    float fft  = get_fft(uv.x);
warp_9=`    float wave = get_wave(uv.x);
warp_10=`    float3 col = float3( fft, 4*fft*(1-fft), 1-fft ) * fft;
warp_11=`    col += 1 - smoothstep( 0, .15, abs(wave - uv.y + .5) );
warp_12=`    ret = float4(col,1);
warp_13=`}
comp_1=`shader_body
comp_2=`{ ret = GetPixel(uv); }
